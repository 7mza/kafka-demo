{
  "binary.handling.mode": "bytes",
  "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
  "database.dbname": "${POSTGRES_DB}",
  "database.hostname": "postgres",
  "database.password": "${POSTGRES_PASSWORD}",
  "database.port": "5432",
  "database.user": "${POSTGRES_USER}",
  "key.converter": "org.apache.kafka.connect.storage.StringConverter",
  "plugin.name": "pgoutput",
  "publication.autocreate.mode": "filtered",
  "publication.name": "inventory_outbox_pub",
  "schema.include.list": "inventory-service",
  "slot.name": "inventory_outbox_slot",
  "table.include.list": "inventory-service.orders_outbox",
  "tasks.max": "1",
  "tombstones.on.delete": "false",
  "topic.creation.default.partitions": "${KAFKA_PARTITIONS}",
  "topic.creation.default.replication.factor": "${KAFKA_REPLICATION_FACTOR}",
  "topic.prefix": "inventory",
  "transforms": "outbox",
  "transforms.outbox.route.by.field": "topic",
  "transforms.outbox.route.topic.regex": "(?<routedByValue>.*)",
  "transforms.outbox.route.topic.replacement": "${routedByValue}",
  "transforms.outbox.table.expand.json.payload": "false",
  "transforms.outbox.table.field.event.id": "id",
  "transforms.outbox.table.field.event.key": "orderId",
  "transforms.outbox.table.field.event.payload": "avroPayload",
  "transforms.outbox.table.field.event.type": "eventType",
  "transforms.outbox.type": "io.debezium.transforms.outbox.EventRouter",
  "value.converter": "org.apache.kafka.connect.converters.ByteArrayConverter"
}
