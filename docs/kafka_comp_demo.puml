@startuml
skinparam linetype ortho

skinparam component {
    backgroundColor<<leader>> Green
}

cloud "isolation"  {
    rectangle "node 1\n<controller + broker>" as N1 {
        rectangle "topic" as T1N1 {
            [partition1] <<leader>> as N1P1
            [partition2] <<replica>> as N1P2
            [partition3] <<replica>> as N1P3
        }
    }

    rectangle "node 2\n<controller + broker>" as N2 {
        rectangle "topic" as T1N2 {
            [partition1] <<replica>> as N2P1
            [partition2] <<leader>> as N2P2
            [partition3] <<replica>> as N2P3
        }
    }

    rectangle "node 3\n<controller + broker>" as N3 {
        rectangle "topic" as T1N3 {
            [partition1] <<replica>> as N3P1
            [partition2] <<replica>> as N3P2
            [partition3] <<leader>> as N3P3
        }
    }

    N1P1 ..> N2P1: replication
    N1P1 ..> N3P1: replication

    N2P2 ..> N1P2: replication
    N2P2 ..> N3P2: replication

    N3P3 ..> N1P3: replication
    N3P3 ..> N2P3: replication
}

note left
    **KRaft cluster with 3 nodes:**
    - every node is controller + broker
    - replication factor = 3
    - partitions per topic = 3
    - min in sync replicas = 2
    - 1 leader per partition
    - all nodes in same isolation
end note
@enduml
