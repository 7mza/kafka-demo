# DB
POSTGRES_DB=kafka_demo
POSTGRES_PASSWORD=password
POSTGRES_USER=username

# kafka
## list of brokers, initial contact point to pull cluster metadata
KAFKA_BOOTSTRAP_SERVERS=kafka1:19092,kafka2:19092,kafka3:19092
## kafka log level inside spring
KAFKA_LOGGING_LEVEL=error

# orders-api
## how many unpublished outbox messages to fetch for publication
ORDERS_BATCH_SIZE=10
## how many publish attemps to try on each outbox before flagging it as dead letter
ORDERS_MAX_ATTEMPTS=10
## minimum number of replicas to ACK write before leader confirm write
ORDERS_MIN_INSYNC_REPLICAS=2
## how many partitions per topic
ORDERS_PARTITIONS=3
## low freq periodic rescue poll to wake up drain service (if listener on DB notify channel fails)
ORDERS_POLL_DELAY=PT1M
## initial delay (after app starts) before periodic poll triggers
ORDERS_POLL_INITIAL_DELAY=PT1M
## how much time to wait for ACK before considering publish failed
ORDERS_PUBLISH_TIMEOUT=PT5S
## how many replicas per partition
ORDERS_REPLICATION_FACTOR=3
## topic name where placed orders should be sent to
ORDERS_PLACED_TOPIC_NAME=orders.placed

# inventory-service
## how many unprocessed inbox messages to fetch for processing
INVENTORY_BATCH_SIZE=10
## low freq periodic rescue poll to wake up process service (if listener on DB notify channel fails)
INVENTORY_POLL_DELAY=PT1M
## initial delay (after app starts) before periodic poll triggers
INVENTORY_POLL_INITIAL_DELAY=PT1M
## topic name where accepted orders should be sent to
INVENTORY_ACCEPTED_ORDERS_TOPIC_NAME=orders.accepted
## topic name where rejected orders should be sent to
INVENTORY_REJECTED_ORDERS_TOPIC_NAME=orders.rejected
